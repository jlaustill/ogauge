#include <Arduino.h>
#include "display_st7701.cnx"

void setup() {
  Serial.begin(115200);
  Serial.println("OGauge: Display bring-up");

  Serial.println("I2C init...");
  I2C.init();

  Serial.println("TCA9554 init...");
  TCA9554.init(0x00);

  Serial.println("Display init...");
  Display.init();

  Serial.println("Filling screen blue...");
  Display.fill_color(0x001F);

  Serial.println("Done!");
}

void loop() {
  delay(1000);
}
